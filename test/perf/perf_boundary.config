# Dispatch performance regression fixture: BACKLOG / PATHOLOGICAL regime.
# Deliberately undersupplied (high demand, modest supply) so a large backlog of
# unassigned trips builds up while idle (P1) vehicles stay scarce. This is the
# case the old cost rule got wrong: it flipped to the dense (location-ring)
# search and ring-searched a near-empty grid for thousands of queued trips.
# The corrected rule must keep large-backlog blocks on the sparse search.
# Trimmed time_blocks for test speed (the backlog still grows into the
# hundreds/thousands within this window).
# Used by test/test_dispatch_performance.py.

[DEFAULT]
city_size = 64
vehicle_count = 110
base_demand = 55.0
mean_trip_distance = 12
time_blocks = 80
idle_vehicles_moving = 1.0
random_number_seed = 42
animation = none
equilibration = none
