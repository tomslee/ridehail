# Dispatch performance regression fixture: DENSE regime.
# Moderate city, many idle vehicles -> P1 >> city_size, so every block should
# select the dense (location-ring) search. Trimmed time_blocks for test speed.
# Used by test/test_dispatch_performance.py.

[DEFAULT]
city_size = 32
vehicle_count = 800
base_demand = 30.0
mean_trip_distance = 8
time_blocks = 50
idle_vehicles_moving = 1.0
random_number_seed = 42
animation = none
equilibration = none
