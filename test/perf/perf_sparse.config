# Dispatch performance regression fixture: SPARSE regime.
# Large city, few idle vehicles -> P1 << city_size, so every block should
# select the sparse (vehicle-loop) search. Trimmed time_blocks for test speed.
# Used by test/test_dispatch_performance.py (not auto-discovered by the value
# regression, which only globs test/*.config).

[DEFAULT]
city_size = 64
vehicle_count = 40
base_demand = 8.0
mean_trip_distance = 16
time_blocks = 60
idle_vehicles_moving = 1.0
random_number_seed = 42
animation = none
equilibration = none
